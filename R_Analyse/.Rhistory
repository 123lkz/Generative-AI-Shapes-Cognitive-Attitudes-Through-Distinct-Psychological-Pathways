install.packages(c("lme4", "lmerTest", "emmeans", "readr", "dplyr"))
library(lme4)
library(lmerTest)
library(emmeans)
library(readr)
library(dplyr)
# 1. 加载包
library(tidyverse)
library(lme4)
library(lmerTest)
library(emmeans)
# 2. 如果还没有读入数据，先读入
# 如果你已经有 dat，可以跳过这一行
dat <- read.csv("PBS_long_tidy_minimal.csv")
# 3. 整理变量格式
dat <- dat %>%
  mutate(
    id = factor(id),
    topic_id = factor(topic_id),
    phase = factor(phase),
    period = factor(period),
    condition = factor(condition),
    order_group = factor(order_group),
    age_c = as.numeric(scale(age, center = TRUE, scale = FALSE))
  )
# 4. 只保留干预阶段数据
dat_int <- dat %>%
  filter(phase == "intervention") %>%
  mutate(
    condition = factor(condition, levels = c("control", "combined")),
    topic_id = factor(topic_id),
    order_group = factor(order_group),
    id = factor(id)
  ) %>%
  droplevels()
# 检查数据
table(dat_int$topic_id, dat_int$condition)
m_topic <- lmer(
  score ~ condition * topic_id + order_group + age_c +
    (1 | id),
  data = dat_int,
  REML = FALSE
)
summary(m_topic)
anova(m_topic, type = 3, ddf = "Satterthwaite")
emm_topic_condition <- emmeans(
  m_topic,
  ~ condition | topic_id
)
emm_topic_condition
combined - control
topic_contrast <- contrast(
  emm_topic_condition,
  method = list("combined - control" = c(-1, 1)),
  by = "topic_id",
  adjust = "none"
)
summary(topic_contrast)
topic_result_bonf <- as.data.frame(summary(topic_contrast)) %>%
  mutate(
    p_bonf = pmin(p.value * 3, 1),
    sig_bonf = case_when(
      p_bonf < .001 ~ "***",
      p_bonf < .01  ~ "**",
      p_bonf < .05  ~ "*",
      TRUE ~ "ns"
    ),
    p_bonf_label = case_when(
      p_bonf < .001 ~ "< .001",
      TRUE ~ paste0("= ", round(p_bonf, 3))
    )
  )
topic_result_bonf
q()
